# FireRedASR2S — 示例脚本共用（复制为仓库根目录下的 .env 或合并到现有 .env）
# 勿将含真实密钥的 .env 提交到版本库。

# ---------- 真·LLM（OpenAI 兼容 /chat/completions）----------
# Base URL 优先级（脚本内）：LLM_BASE_URL > OLLAMA_BASE_URL > OPENAI_BASE_URL
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=http://127.0.0.1:11434/v1

# 模型优先级：LLM_MODEL_ID > LLM_MODEL > OLLAMA_MODEL
# LLM_MODEL_ID=gpt-4o-mini

# 密钥优先级：显式 --api-key > LLM_API_KEY > OPENAI_API_KEY
# LLM_API_KEY=sk-your-key-here

# LLM_TIMEOUT=120

# 真机「急躁打断 → 真 LLM 重讲」：examples/full_duplex_voice_llm_tts.py --impatient-barge-in（读上述 LLM 变量）
# 多轮接听/打断/告别回放（可重复验收）：scripts/prepare_rich_call_scenario_wavs.py → examples/full_duplex_rich_call_llm_sim.py

# ---------- ASR / 推理设备（各示例 --device 的默认值 = xpu）----------
# 仅以下变量生效（其它项目里的 ASR_DEVICE 不会影响本仓库示例，避免默认变成 cpu）：
# FIRERED_ASR_DEVICE=xpu
